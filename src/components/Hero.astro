---
import site from "../data/site.json";
---

<section class="relative overflow-hidden py-20 sm:py-28">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-sage/25 via-transparent to-transparent"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <p class="text-sm font-medium uppercase tracking-wider text-muted">{site.location}</p>
    <h1 class="mt-3 max-w-3xl font-serif text-4xl font-semibold leading-tight text-forest sm:text-5xl lg:text-6xl">
      {site.name}
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted sm:text-xl">
      {site.tagline}
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href={site.writing[1].url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg bg-forest px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-forest-dark"
      >
        Read on Substack
      </a>
      <a
        href="#tools"
        class="inline-flex items-center rounded-lg border border-forest/30 bg-white px-5 py-3 text-sm font-semibold text-forest transition hover:border-forest hover:bg-canvas"
      >
        Explore Tools
      </a>
      <a
        href="#books"
        class="inline-flex items-center rounded-lg border border-sage bg-sage/20 px-5 py-3 text-sm font-semibold text-forest transition hover:bg-sage/35"
      >
        View Books
      </a>
    </div>
  </div>
</section>
