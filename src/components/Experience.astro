---
import site from "../data/site.json";

type ExperienceEntry = (typeof site.experience)[number];
---

<section id="experience" class="scroll-mt-24 border-t border-sage/30 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <header class="mb-10 max-w-2xl">
      <h2 class="font-serif text-3xl font-semibold text-forest sm:text-4xl">Experience</h2>
      <p class="mt-3 text-lg text-muted">
        Career path from engineering and database patents to wealth management, publishing, and DIY
        investor tools.
      </p>
    </header>

    <ol class="relative space-y-0 border-l-2 border-sage/60 pl-8 sm:pl-10">
      {
        site.experience.map((entry: ExperienceEntry) => (
          <li class="relative pb-10 last:pb-0">
            <span
              class="absolute -left-[2.55rem] top-1.5 h-4 w-4 rounded-full border-2 border-sage bg-canvas sm:-left-[2.85rem]"
              aria-hidden="true"
            />
            <div class="rounded-2xl border border-sage/50 bg-white p-5 shadow-sm sm:p-6">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h3 class="font-serif text-lg font-semibold text-forest">{entry.title}</h3>
                {entry.dates && (
                  <time class="text-sm font-medium text-muted">{entry.dates}</time>
                )}
              </div>
              <p class="mt-1 text-sm font-medium text-forest/90">{entry.organization}</p>
              {entry.location && <p class="text-sm text-muted">{entry.location}</p>}
              {entry.description && (
                <p class="mt-3 text-sm leading-relaxed text-muted">{entry.description}</p>
              )}
              {entry.url && (
                <a
                  href={entry.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-3 inline-block text-sm font-semibold text-forest hover:underline"
                >
                  View credential →
                </a>
              )}
            </div>
          </li>
        ))
      }
    </ol>

    {
      site.awards && site.awards.length > 0 && (
        <div class="mt-12 rounded-2xl border border-sage/50 bg-white p-6 shadow-sm">
          <h3 class="font-serif text-lg font-semibold text-forest">Awards & presentations</h3>
          <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-muted">
            {site.awards.map((award) => (
              <li>{award}</li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="mt-8 text-sm text-muted">
      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="font-semibold text-forest hover:underline"
      >
        View full profile on LinkedIn →
      </a>
    </p>
  </div>
</section>
