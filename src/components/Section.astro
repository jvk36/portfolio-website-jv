---
interface Props {
  id: string;
  title: string;
  lead?: string;
}

const { id, title, lead } = Astro.props;
---

<section id={id} class="scroll-mt-24 border-t border-sage/30 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <header class="mb-10 max-w-2xl">
      <h2 class="font-serif text-3xl font-semibold text-forest sm:text-4xl">{title}</h2>
      {lead && <p class="mt-3 text-lg text-muted">{lead}</p>}
    </header>
    <slot />
  </div>
</section>
