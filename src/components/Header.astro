---
const nav = [
  { href: "#about", label: "About" },
  { href: "#writing", label: "Writing" },
  { href: "#tools", label: "Tools" },
  { href: "#books", label: "Books" },
  { href: "#patents", label: "Patents" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-sage/40 bg-canvas/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6">
    <a href="#" class="font-serif text-lg font-semibold text-forest">JKV</a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-muted transition-colors hover:text-forest"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <details class="relative md:hidden">
      <summary
        class="cursor-pointer list-none rounded-lg border border-sage/60 px-3 py-2 text-sm font-medium text-forest [&::-webkit-details-marker]:hidden"
      >
        Menu
      </summary>
      <nav
        class="absolute right-0 mt-2 w-48 rounded-xl border border-sage/50 bg-white p-3 shadow-lg"
        aria-label="Mobile"
      >
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="block rounded-md px-3 py-2 text-sm text-muted hover:bg-canvas hover:text-forest"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
