---
import site from "../data/site.json";
---

<section id="skills" class="scroll-mt-24 border-t border-sage/30 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <header class="mb-10 max-w-2xl">
      <h2 class="font-serif text-3xl font-semibold text-forest sm:text-4xl">Skills</h2>
      <p class="mt-3 text-lg text-muted">Database systems, data-intensive computing, and modern AI/ML stacks.</p>
    </header>
    <ul class="flex flex-wrap gap-2">
      {
        site.skills.map((skill) => (
          <li>
            <span class="inline-block rounded-full border border-sage/60 bg-white px-3 py-1.5 text-sm font-medium text-charcoal shadow-sm">
              {skill}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
