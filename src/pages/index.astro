---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import Skills from "../components/Skills.astro";
import Experience from "../components/Experience.astro";
import Footer from "../components/Footer.astro";
import site from "../data/site.json";
---

<Layout>
  <Header />
  <main>
    <Hero />

    <Section id="about" title="About" lead="Engineering, patents, investing, and publishing.">
      <p class="max-w-3xl text-lg leading-relaxed text-charcoal/90">{site.about}</p>
    </Section>

    <Skills />

    <Section id="writing" title="Writing" lead="Investing-focused publications, 2011 – present.">
      <div class="grid gap-6 sm:grid-cols-2">
        {
          site.writing.map((item) => (
            <article class="flex flex-col rounded-2xl border border-sage/50 bg-white p-6 shadow-sm transition hover:shadow-md">
              <h3 class="font-serif text-xl font-semibold text-forest">{item.name}</h3>
              <p class="mt-2 flex-1 text-muted">{item.description}</p>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex w-fit items-center rounded-lg bg-forest px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-forest-dark"
              >
                Visit →
              </a>
            </article>
          ))
        }
      </div>
    </Section>

    <Section id="tools" title="DIY Investor Tools" lead="Live dashboards built for personal research workflows.">
      <div class="grid gap-6 sm:grid-cols-2">
        {
          site.tools.map((tool) => (
            <article class="flex flex-col rounded-2xl border border-sage/50 bg-white p-6 shadow-sm transition hover:shadow-md">
              <a
                href={"previewUrl" in tool && tool.previewUrl ? tool.previewUrl : tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mb-4 block overflow-hidden rounded-xl border border-sage/40 bg-white"
              >
                <img
                  src={tool.image}
                  alt={`${tool.name} screenshot`}
                  class="h-48 w-full object-cover object-top"
                  loading="lazy"
                  width="640"
                  height="360"
                />
              </a>
              <h3 class="font-serif text-lg font-semibold text-forest">{tool.name}</h3>
              <p class="mt-2 flex-1 text-muted">{tool.description}</p>
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex w-fit items-center text-sm font-semibold text-forest underline-offset-4 hover:underline"
              >
                Launch app →
              </a>
            </article>
          ))
        }
      </div>
    </Section>

    <Section id="books" title="Books" lead="Hedge funds, Bitcoin, and crypto — written for curious investors.">
      <div class="grid gap-8 lg:grid-cols-3">
        {
          site.books.map((book) => (
            <article class="flex flex-col rounded-2xl border border-sage/50 bg-white p-6 shadow-sm">
              <div class="mb-4 overflow-hidden rounded-lg border border-sage/40 bg-white">
                <img
                  src={book.image}
                  alt={`${book.title} cover`}
                  class="aspect-[2/3] w-full object-cover"
                  loading="lazy"
                  width="400"
                  height="600"
                />
              </div>
              <p class="text-xs font-medium uppercase tracking-wide text-muted">{book.subtitle}</p>
              <h3 class="mt-2 font-serif text-xl font-semibold text-forest">{book.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{book.description}</p>
              <a
                href={book.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex w-fit rounded-lg border border-forest/30 px-4 py-2.5 text-sm font-semibold text-forest transition hover:bg-forest hover:text-white"
              >
                Amazon
              </a>
            </article>
          ))
        }
      </div>
    </Section>

    <Section id="patents" title="Patents" lead="Database and query tooling — U.S. patents.">
      <div class="overflow-hidden rounded-2xl border border-sage/50 bg-white shadow-sm">
        <table class="w-full text-left text-sm">
          <thead class="border-b border-sage/40 bg-canvas">
            <tr>
              <th class="px-4 py-3 font-semibold text-forest sm:px-6">Patent</th>
              <th class="hidden px-4 py-3 font-semibold text-forest sm:table-cell sm:px-6">Year</th>
              <th class="hidden px-4 py-3 font-semibold text-forest lg:table-cell lg:px-6">Title</th>
              <th class="px-4 py-3 font-semibold text-forest sm:px-6"></th>
            </tr>
          </thead>
          <tbody>
            {
              site.patents.map((patent) => (
                <tr class="border-b border-sage/20 last:border-0">
                  <td class="px-4 py-4 font-mono text-xs text-forest sm:px-6 sm:text-sm">{patent.number}</td>
                  <td class="hidden px-4 py-4 text-muted sm:table-cell sm:px-6">{patent.year}</td>
                  <td class="hidden px-4 py-4 text-muted lg:table-cell lg:px-6">{patent.title}</td>
                  <td class="px-4 py-4 text-right sm:px-6">
                    <a
                      href={patent.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="whitespace-nowrap font-semibold text-forest hover:underline"
                    >
                      Google Patents
                    </a>
                    <p class="mt-1 text-muted sm:hidden">{patent.title}</p>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </Section>

    <Experience />
  </main>
  <Footer />
</Layout>
